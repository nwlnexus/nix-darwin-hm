# connectivity failure without --no-verify still exits 0
MEM0_URL="http://127.0.0.1:1" bash "$MEM0CTL" enable >/dev/null 2>&1 && ok "enable warn-only on unreachable" || no "enable warn-only on unreachable (nonzero)"
