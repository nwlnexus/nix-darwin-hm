{
  config,
  pkgs,
  lib,
  ...
}:

with lib;

let
  cfg = config.d.autostart;
in

{
  options.d.autostart = mkOption {
    type = types.attrsOf (
      types.submodule {
        options = {
          exec = mkOption { type = types.str; };
        };
      }
    );
    default = { };
  };

  config = mkIf pkgs.stdenv.isLinux {
    systemd.user.services = mapAttrs (name: opts: {
      Service = {
        Type = "simple";
        Restart = "on-failure";
