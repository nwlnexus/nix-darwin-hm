    # For: Corporate programs e.g. Zoom, Slack, etc.
    business.enable = mkBool false;

    # For: Gaming related programs e.g. Steam
    gaming.enable = mkBool false;
  };

  imports = [
    ./profiles/base.nix
    ./profiles/dev.nix
    ./profiles/gui-small.nix
    ./profiles/gui-full.nix
    ./profiles/business.nix
    # ./profiles/gaming.nix
